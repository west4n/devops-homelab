# Application
NODE_ENV=production
APP_URL=https://app.example.com

# Payload
PAYLOAD_SECRET=change-me

# PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://app:change-me@postgres:5432/app

# Docker registry
REGISTRY_URL=nexus.example.com
IMAGE_NAME=nextjs-payload-app
IMAGE_TAG=v0.1.0